# ============================================================
# AI Travel Concierge — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env
# ============================================================

# Google Gemini API Key (for LLM)
# Get yours at: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash

# OpenWeatherMap API Key (for weather data)
# Get yours at: https://openweathermap.org/api (Free tier available)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google Places API Key (for attractions & points of interest)
# Get yours at: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Aviationstack API Key (for real-time flight tracking)
# Get yours at: https://aviationstack.com/
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here

# Foursquare Places API Key (for hotel search)
# Get yours at: https://location.foursquare.com/developer/
FOURSQUARE_API_KEY=your_foursquare_api_key_here
